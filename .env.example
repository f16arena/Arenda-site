KASPI_API_KEY=""
KASPI_WEBHOOK_SECRET=""
KASPI_API_BASE_URL="https://kaspi.kz/api/v01"
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
