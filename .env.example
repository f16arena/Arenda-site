AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
ROOT_HOST="localhost:3000"
# SETUP_SECRET: 32+ случайных alphanumeric. Сгенерировать:
#   openssl rand -base64 32
SETUP_SECRET="random-secret-for-one-time-setup"
# Установить "true" только во время инициализации /api/setup, потом убрать обратно.
# В production эндпоинт /api/setup ОТКЛЮЧЁН пока SETUP_ENABLED не равно "true".
SETUP_ENABLED="false"
CRON_SECRET="random-secret-for-vercel-cron"
# ALLOWED_ORIGINS: comma-separated list of allowed host suffixes for /api/setup CSRF guard.
ALLOWED_ORIGINS="commrent.kz,localhost"
RESEND_API_KEY=""
EMAIL_FROM="Commrent <noreply@commrent.kz>"
# Kaspi Pay (опционально — без них Kaspi-интеграция отключена).
# Получить через kaspi.kz/business → API для приёма платежей.
