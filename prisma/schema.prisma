generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  name            String
  phone           String?  @unique
  email           String?  @unique
  password        String
  role            String   @default("TENANT")
  isActive        Boolean  @default(true)  @map("is_active")
  telegramChatId  String?  @map("telegram_chat_id")
  organizationId  String?  @map("organization_id")  // null только для PLATFORM_OWNER
  isPlatformOwner Boolean  @default(false) @map("is_platform_owner")
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  // Настройки каналов уведомлений (true = включён, по умолчанию всё включено)
  notifyEmail     Boolean   @default(true) @map("notify_email")
  notifyTelegram  Boolean   @default(true) @map("notify_telegram")
  notifyInApp     Boolean   @default(true) @map("notify_in_app")
  notifySms       Boolean   @default(false) @map("notify_sms")  // SMS дороже — выключено по умолчанию
  // Какие типы событий присылать (JSON-объект с булевыми полями)
  // Если null — все типы включены. Иначе ключ с false выключает уведомления этого типа.
  notifyMutedTypes Json?    @map("notify_muted_types")
  // 2FA (TOTP) — base32 secret для Google Authenticator. enabledAt = когда включена.
  totpSecret      String?  @map("totp_secret")
  totpEnabledAt   DateTime? @map("totp_enabled_at")
  // Резервные коды для входа без приложения (хешированные)
  totpBackupCodes Json?    @map("totp_backup_codes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  organization     Organization?    @relation(fields: [organizationId], references: [id])
  tenant           Tenant?
  staff            Staff?
  sentMessages     Message[]        @relation("MessageSender")
  receivedMessages Message[]        @relation("MessageReceiver")
  assignedTasks    Task[]           @relation("TaskAssignee")
  createdTasks     Task[]           @relation("TaskCreator")
  requests         Request[]
  requestComments  RequestComment[]
  complaints       Complaint[]
  notifications    Notification[]
  administeredBuildings Building[]  @relation("BuildingAdmin")

  @@index([organizationId])
  @@map("users")
}

// API-ключи для внешних интеграций (1С, Excel-скрипты, мониторинги).
// Каждый ключ scoped к организации, имеет права read/write и срок действия.
model ApiKey {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String                            // как создатель назвал ключ
  keyHash        String    @unique @map("key_hash") // bcrypt хеш токена
  keyPrefix      String    @map("key_prefix")       // первые 8 символов для отображения
  scope          String    @default("READ")        // READ | WRITE
  expiresAt      DateTime? @map("expires_at")
  lastUsedAt     DateTime? @map("last_used_at")
  revokedAt      DateTime? @map("revoked_at")
  createdById    String?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("api_keys")
}

model Organization {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  isActive        Boolean   @default(true) @map("is_active")
  isSuspended     Boolean   @default(false) @map("is_suspended")
  ownerUserId     String?   @map("owner_user_id")
  planId          String?   @map("plan_id")
  planExpiresAt   DateTime? @map("plan_expires_at")
  // НДС: для арендодателя — выставляются ли документы с НДС
  isVatPayer      Boolean   @default(false) @map("is_vat_payer")
  vatRate         Float     @default(12)    @map("vat_rate")
  vatNumber       String?   @map("vat_number")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  plan          Plan?           @relation(fields: [planId], references: [id])
  buildings     Building[]
  users         User[]
  subscriptions Subscription[]
  cashAccounts  CashAccount[]
  apiKeys       ApiKey[]

  @@map("organizations")
}

// Денежные счета организации (банковские счета, касса, карты).
// Используются для отслеживания баланса (сколько денег где).
model CashAccount {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String   // "Каспи Банк", "Касса", "Halyk Business"
  type           String   // BANK | CASH | CARD
  balance        Float    @default(0)
  currency       String   @default("KZT")
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions CashTransaction[]

  @@index([organizationId])
  @@map("cash_accounts")
}

// Транзакции по денежным счетам (приход/расход/корректировка).
model CashTransaction {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  amount      Float    // Положительное = приход, отрицательное = расход
  type        String   // DEPOSIT | WITHDRAW | ADJUSTMENT | TRANSFER_OUT | TRANSFER_IN
  description String?
  date        DateTime @default(now())
  createdById String?  @map("created_by_id")
  // Опциональная связь с другими сущностями
  paymentId   String?  @map("payment_id")
  expenseId   String?  @map("expense_id")
  createdAt   DateTime @default(now()) @map("created_at")

  account CashAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, date])
  @@map("cash_transactions")
}

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  priceMonthly Float    @default(0) @map("price_monthly")
  priceYearly  Float    @default(0) @map("price_yearly")
  maxBuildings Int?     @map("max_buildings")
  maxTenants   Int?     @map("max_tenants")
  maxUsers     Int?     @map("max_users")
  maxLeads     Int?     @map("max_leads")
  features     String   @default("{}")  // JSON
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  organizations Organization[]
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  planId         String   @map("plan_id")
  startedAt      DateTime @default(now()) @map("started_at")
  expiresAt      DateTime @map("expires_at")
  status         String   @default("ACTIVE")
  paidAmount     Float    @default(0) @map("paid_amount")
  paymentMethod  String?  @map("payment_method")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@map("subscriptions")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   // CONTRACT_EXPIRING | PAYMENT_DUE | NEW_REQUEST | NEW_COMPLAINT | INFO
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Building {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  name            String
  address         String
  description     String?
  phone           String?
  email           String?
  responsible     String?
  // Администратор здания — User с ролью ADMIN, к которому идут все вопросы по аренде.
  // Иерархия: Owner → Administrator → Tenants.
  administratorUserId String? @map("administrator_user_id")
  totalArea       Float?   @map("total_area")
  // Per-building нумерация документов: префикс — настраиваемый (например, F16),
  // счётчик инкрементируется при подтверждении номера. Уникальность контролируется
  // в пределах здания на текущий год.
  contractPrefix         String? @map("contract_prefix")
  contractCounter        Int     @default(0) @map("contract_counter")
  invoicePrefix          String? @map("invoice_prefix")
  invoiceCounter         Int     @default(0) @map("invoice_counter")
  actPrefix              String? @map("act_prefix")
  actCounter             Int     @default(0) @map("act_counter")
  reconciliationPrefix   String? @map("reconciliation_prefix")
  reconciliationCounter  Int     @default(0) @map("reconciliation_counter")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  administrator     User?             @relation("BuildingAdmin", fields: [administratorUserId], references: [id], onDelete: SetNull)
  floors            Floor[]
  emergencyContacts EmergencyContact[]
  expenses          Expense[]
  tariffs           Tariff[]
  leads             Lead[]

  @@index([organizationId])
  @@map("buildings")
}

model Tariff {
  id          String   @id @default(cuid())
  buildingId  String   @map("building_id")
  type        String   // ELECTRICITY | WATER | HEATING | GARBAGE | INTERNET | OTHER
  name        String
  rate        Float
  unit        String   @default("ед.")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@map("tariffs")
}

model Floor {
  id               String  @id @default(cuid())
  buildingId       String  @map("building_id")
  number           Int
  name             String
  ratePerSqm       Float   @default(0) @map("rate_per_sqm")
  totalArea        Float?  @map("total_area")
  layoutJson       String? @map("layout_json")
  fixedMonthlyRent Float?  @map("fixed_monthly_rent")
  fullFloorTenantId String? @map("full_floor_tenant_id")

  building       Building @relation(fields: [buildingId], references: [id])
  spaces         Space[]
  fullFloorTenant Tenant? @relation("FullFloorTenant", fields: [fullFloorTenantId], references: [id])

  @@map("floors")
}

model Space {
  id          String  @id @default(cuid())
  floorId     String  @map("floor_id")
  number      String
  area        Float
  status      String  @default("VACANT")
  // RENTABLE = арендопригодное помещение (можно сдать)
  // COMMON = общая зона: коридор, лестница, санузел, тех. помещение —
  // не сдаётся, не считается в заполняемости, не появляется в списке свободных.
  kind        String  @default("RENTABLE")
  description String?

  floor  Floor   @relation(fields: [floorId], references: [id])
  tenant Tenant?
  meters Meter[]

  @@map("spaces")
}

model Tenant {
  id               String    @id @default(cuid())
  userId           String    @unique @map("user_id")
  spaceId          String?   @unique @map("space_id")
  companyName      String    @map("company_name")
  bin              String?
  iin              String?
  bankName         String?   @map("bank_name")
  iik              String?
  bik              String?
  legalType        String    @default("IP") @map("legal_type")
  category         String?
  legalAddress     String?   @map("legal_address")
  actualAddress    String?   @map("actual_address")
  directorName     String?   @map("director_name")
  directorPosition String?   @map("director_position")
  needsCleaning    Boolean   @default(false) @map("needs_cleaning")
  cleaningFee      Float     @default(0)     @map("cleaning_fee")
  customRate       Float?    @map("custom_rate")
  fixedMonthlyRent Float?    @map("fixed_monthly_rent")
  contractStart    DateTime? @map("contract_start")
  contractEnd      DateTime? @map("contract_end")
  paymentDueDay    Int       @default(10) @map("payment_due_day")
  penaltyPercent   Float     @default(1) @map("penalty_percent")
  // Является ли арендатор плательщиком НДС (для будущей ЭСФ)
  isVatPayer       Boolean   @default(false) @map("is_vat_payer")
  // Чёрный список: причина и время попадания. Если != null — нельзя завести
  // нового арендатора с таким БИН/ИИН (предупреждение администратору).
  blacklistedAt    DateTime? @map("blacklisted_at")
  blacklistReason  String?   @map("blacklist_reason")
  createdAt        DateTime  @default(now()) @map("created_at")

  user        User             @relation(fields: [userId], references: [id])
  space       Space?           @relation(fields: [spaceId], references: [id])
  charges     Charge[]
  payments    Payment[]
  contracts   Contract[]
  documents   TenantDocument[]
  requests    Request[]
  fullFloors  Floor[]          @relation("FullFloorTenant")

  @@map("tenants")
}

model Staff {
  id       String   @id @default(cuid())
  userId   String   @unique @map("user_id")
  position String
  salary   Float    @default(0)
  hireDate DateTime @default(now()) @map("hire_date")

  user           User            @relation(fields: [userId], references: [id])
  salaryPayments SalaryPayment[]

  @@map("staff")
}

model Contract {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  number    String
  type      String    @default("STANDARD")
  content   String
  // Workflow статусы:
  // DRAFT → SENT → VIEWED → SIGNED_BY_TENANT → SIGNED (обе стороны)
  // или альтернативные: REJECTED, EXPIRED
  status    String    @default("DRAFT")
  signedAt  DateTime? @map("signed_at")
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  // Workflow подписания:
  signToken          String?   @unique @map("sign_token")  // токен для уникальной ссылки tenant'у
  sentAt             DateTime? @map("sent_at")             // когда отправлено арендатору
  viewedAt           DateTime? @map("viewed_at")           // когда арендатор открыл ссылку
  signedByTenantAt   DateTime? @map("signed_by_tenant_at")
  signedByTenantName String?   @map("signed_by_tenant_name") // ФИО подписавшего
  signedByLandlordAt DateTime? @map("signed_by_landlord_at")
  rejectedAt         DateTime? @map("rejected_at")
  rejectionReason    String?   @map("rejection_reason")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("contracts")
}

model Charge {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  period      String
  type        String
  amount      Float
  description String?
  isPaid      Boolean   @default(false) @map("is_paid")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("charges")
}

model Payment {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  amount      Float
  paymentDate DateTime @map("payment_date")
  method      String   @default("TRANSFER")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("payments")
}

model Meter {
  id      String @id @default(cuid())
  spaceId String @map("space_id")
  type    String
  number  String

  space    Space          @relation(fields: [spaceId], references: [id])
  readings MeterReading[]

  @@map("meters")
}

model MeterReading {
  id        String   @id @default(cuid())
  meterId   String   @map("meter_id")
  period    String
  value     Float
  previous  Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  meter Meter @relation(fields: [meterId], references: [id])

  @@map("meter_readings")
}

model Request {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  title       String
  description String
  type        String   @default("OTHER")
  priority    String   @default("MEDIUM")
  status      String   @default("NEW")
  assigneeId  String?  @map("assignee_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  user     User             @relation(fields: [userId], references: [id])
  comments RequestComment[]

  @@map("requests")
}

model RequestComment {
  id        String   @id @default(cuid())
  requestId String   @map("request_id")
  authorId  String   @map("author_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  request Request @relation(fields: [requestId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])

  @@map("request_comments")
}

model Task {
  id            String    @id @default(cuid())
  buildingId    String?   @map("building_id")
  title         String
  description   String?
  category      String    @default("OTHER")
  floorNumber   Int?      @map("floor_number")
  spaceNumber   String?   @map("space_number")
  estimatedCost Float?    @map("estimated_cost")
  actualCost    Float?    @map("actual_cost")
  dueDate       DateTime? @map("due_date")
  status        String    @default("NEW")
  priority      String    @default("MEDIUM")
  createdById   String    @map("created_by_id")
  assignedToId  String?   @map("assigned_to_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")

  createdBy  User  @relation("TaskCreator",  fields: [createdById],  references: [id])
  assignedTo User? @relation("TaskAssignee", fields: [assignedToId], references: [id])

  @@map("tasks")
}

model Expense {
  id          String   @id @default(cuid())
  buildingId  String   @map("building_id")
  category    String
  amount      Float
  period      String
  description String?
  date        DateTime
  createdAt   DateTime @default(now()) @map("created_at")

  building Building @relation(fields: [buildingId], references: [id])

  @@map("expenses")
}

model SalaryPayment {
  id        String    @id @default(cuid())
  staffId   String    @map("staff_id")
  amount    Float
  period    String
  paidAt    DateTime? @map("paid_at")
  status    String    @default("PENDING")
  createdAt DateTime  @default(now()) @map("created_at")

  staff Staff @relation(fields: [staffId], references: [id])

  @@map("salary_payments")
}

model TenantDocument {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  type      String
  name      String
  fileUrl   String   @map("file_url")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_documents")
}

model Message {
  id            String   @id @default(cuid())
  fromId        String   @map("from_id")
  toId          String   @map("to_id")
  subject       String?
  body          String
  isRead        Boolean  @default(false) @map("is_read")
  attachmentUrl String?  @map("attachment_url")
  createdAt     DateTime @default(now()) @map("created_at")

  from User @relation("MessageSender",   fields: [fromId], references: [id])
  to   User @relation("MessageReceiver", fields: [toId],   references: [id])

  @@map("messages")
}

model EmergencyContact {
  id         String @id @default(cuid())
  buildingId String @map("building_id")
  name       String
  phone      String
  category   String

  building Building @relation(fields: [buildingId], references: [id])

  @@map("emergency_contacts")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  userName   String?  @map("user_name")
  userRole   String?  @map("user_role")
  action     String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT
  entity     String   // tenant | building | charge | payment | space | user | ...
  entityId   String?  @map("entity_id")
  details    String?  // JSON с deltaмiBefore/After
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Lead {
  id            String    @id @default(cuid())
  buildingId    String    @map("building_id")
  name          String
  contact       String    // phone or email
  contactType   String    @default("PHONE") @map("contact_type")
  companyName   String?   @map("company_name")
  legalType     String?   @map("legal_type")
  desiredArea   Float?    @map("desired_area")
  budget        Float?
  spaceId       String?   @map("space_id")
  source        String    @default("OTHER") // SITE | KRISHA | OLX | WORD_OF_MOUTH | OTHER
  status        String    @default("NEW")   // NEW | SHOWN | NEGOTIATION | SIGNED | LOST
  notes         String?
  bookedUntil   DateTime? @map("booked_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@index([status])
  @@map("leads")
}

model EmailLog {
  id         String    @id @default(cuid())
  recipient  String
  subject    String
  type       String    // INVOICE | ACT | CONTRACT | NOTIFICATION | OTHER
  tenantId   String?   @map("tenant_id")
  userId     String?   @map("user_id")
  externalId String?   @map("external_id")
  status     String    @default("SENT")
  error      String?
  openedAt   DateTime? @map("opened_at")
  openCount  Int       @default(0) @map("open_count")
  sentAt     DateTime  @default(now()) @map("sent_at")

  @@index([tenantId])
  @@index([userId])
  @@index([sentAt])
  @@map("email_logs")
}

model RolePermission {
  id        String   @id @default(cuid())
  role      String   // OWNER | ADMIN | ACCOUNTANT | FACILITY_MANAGER | TENANT
  section   String   // dashboard | buildings | spaces | tenants | finances | meters | contracts | requests | tasks | staff | complaints | messages | analytics | settings | roles | users | documents
  canView   Boolean  @default(false) @map("can_view")
  canEdit   Boolean  @default(false) @map("can_edit")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([role, section])
  @@map("role_permissions")
}

model Complaint {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  name      String?
  text      String
  status    String   @default("NEW")
  response  String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("complaints")
}

// Кастомный шаблон документа на уровне организации.
// На каждый тип (CONTRACT / INVOICE / ACT / RECONCILIATION) хранится один
// активный шаблон (предыдущие — деактивированные, для истории).
// DOCX (через docxtemplater) и XLSX (через ExcelJS) — для генерации.
// PDF — только как образец-превью, не для подстановки.
model DocumentTemplate {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  documentType   String   @map("document_type")
  format         String
  fileName       String   @map("file_name")
  fileBytes      Bytes    @map("file_bytes")
  fileSize       Int      @map("file_size")
  isActive       Boolean  @default(true) @map("is_active")
  uploadedById   String?  @map("uploaded_by_id")
  uploadedAt     DateTime @default(now()) @map("uploaded_at")
  notes          String?

  @@index([organizationId, documentType, isActive])
  @@map("document_templates")
}

// Архив сгенерированных документов — для повторного скачивания и фильтра.
model GeneratedDocument {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  documentType   String   @map("document_type")
  number         String?
  tenantId       String?  @map("tenant_id")
  tenantName     String   @map("tenant_name")
  period         String?
  totalAmount    Float?   @map("total_amount")
  fileName       String   @map("file_name")
  fileBytes      Bytes    @map("file_bytes")
  fileSize       Int      @map("file_size")
  format         String   @default("DOCX")
  generatedById  String?  @map("generated_by_id")
  generatedAt    DateTime @default(now()) @map("generated_at")
  templateUsedId String?  @map("template_used_id")

  @@index([organizationId, documentType])
  @@index([organizationId, period])
  @@index([tenantId])
  @@map("generated_documents")
}

// Хранилище ЭЦП-подписей документов через NCALayer (НУЦ РК).
// Один документ может быть подписан несколькими сторонами (арендодатель + арендатор).
model DocumentSignature {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  documentType    String    @map("document_type") // CONTRACT | INVOICE | ACT | RECONCILIATION | HANDOVER
  documentId      String?   @map("document_id")
  documentRef     String?   @map("document_ref")
  signerUserId    String?   @map("signer_user_id")
  signerName      String    @map("signer_name")
  signerIin       String?   @map("signer_iin")
  signerOrgBin    String?   @map("signer_org_bin")
  signedHashB64   String    @map("signed_hash_b64")
  signatureB64    String    @map("signature_b64")
  certPemB64      String    @map("cert_pem_b64")
  validFrom       DateTime? @map("valid_from")
  validTo         DateTime? @map("valid_to")
  algorithm       String    @default("RSA-SHA256") @map("algorithm")
  signedAt        DateTime  @default(now()) @map("signed_at")

  @@index([organizationId])
  @@index([documentType, documentId])
  @@map("document_signatures")
}

// Токены для верификации email/телефона + сброса пароля.
// Один пользователь может иметь несколько активных токенов (разные сценарии).
model VerificationToken {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")  // null для password-reset по email до создания юзера (не используем)
  type      String   // EMAIL_VERIFY | PHONE_VERIFY | PASSWORD_RESET | EMAIL_CHANGE | PHONE_CHANGE
  target    String   // email или телефон
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, type])
  @@index([token])
  @@map("verification_tokens")
}
