generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String    @id @default(cuid())
  name                    String
  phone                   String?   @unique
  email                   String?   @unique
  password                String
  role                    String    @default("TENANT")
  isActive                Boolean   @default(true) @map("is_active")
  // Удаление пользователя из /admin/users (soft): запись цела (FK/аудит), но скрыта.
  deletedAt               DateTime? @map("deleted_at")
  approvalStatus          String    @default("APPROVED") @map("approval_status")
  approvalRequestedAt     DateTime? @map("approval_requested_at")
  approvedAt              DateTime? @map("approved_at")
  approvedById            String?   @map("approved_by_id")
  rejectionReason         String?   @map("rejection_reason")
  telegramChatId          String?   @map("telegram_chat_id")
  organizationId          String?   @map("organization_id") // null только для PLATFORM_OWNER
  isPlatformOwner         Boolean   @default(false) @map("is_platform_owner")
  emailVerifiedAt         DateTime? @map("email_verified_at")
  phoneVerifiedAt         DateTime? @map("phone_verified_at")
  // Принудительная смена пароля при первом входе. true — пользователь не сможет
  // работать в системе, пока не задаст собственный пароль.
  mustChangePassword      Boolean   @default(false) @map("must_change_password")
  passwordChangedAt       DateTime? @map("password_changed_at")
  // Настройки каналов уведомлений (true = включён, по умолчанию всё включено)
  notifyEmail             Boolean   @default(true) @map("notify_email")
  notifyTelegram          Boolean   @default(true) @map("notify_telegram")
  notifyInApp             Boolean   @default(true) @map("notify_in_app")
  notifySms               Boolean   @default(false) @map("notify_sms") // SMS дороже — выключено по умолчанию
  notifyQuietHoursEnabled Boolean   @default(false) @map("notify_quiet_hours_enabled")
  notifyQuietFrom         String    @default("22:00") @map("notify_quiet_from")
  notifyQuietTo           String    @default("08:00") @map("notify_quiet_to")
  // Какие типы событий присылать (JSON-объект с булевыми полями)
  // Если null — все типы включены. Иначе ключ с false выключает уведомления этого типа.
  notifyMutedTypes        Json?     @map("notify_muted_types")
  // 2FA (TOTP) — base32 secret для Google Authenticator. enabledAt = когда включена.
  totpSecret              String?   @map("totp_secret")
  totpEnabledAt           DateTime? @map("totp_enabled_at")
  // Резервные коды для входа без приложения (хешированные)
  totpBackupCodes         Json?     @map("totp_backup_codes")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  organization           Organization?        @relation(fields: [organizationId], references: [id])
  tenant                 Tenant?
  staff                  Staff?
  sentMessages           Message[]            @relation("MessageSender")
  receivedMessages       Message[]            @relation("MessageReceiver")
  assignedTasks          Task[]               @relation("TaskAssignee")
  createdTasks           Task[]               @relation("TaskCreator")
  requests               Request[]
  requestComments        RequestComment[]
  complaints             Complaint[]
  notifications          Notification[]
  administeredBuildings  Building[]           @relation("BuildingAdmin")
  buildingAccess         UserBuildingAccess[]
  sentPaymentReports     PaymentReport[]      @relation("PaymentReportUser")
  reviewedPaymentReports PaymentReport[]      @relation("PaymentReportReviewer")
  uploadedStoredFiles    StoredFile[]         @relation("StoredFileUploader")

  @@index([organizationId])
  @@index([organizationId, role, isActive])
  @@index([organizationId, approvalStatus, role])
  @@index([approvalStatus, createdAt])
  @@map("users")
}

// API-ключи для внешних интеграций (1С, Excel-скрипты, мониторинги).
// Каждый ключ scoped к организации, имеет права read/write и срок действия.
model ApiKey {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String // как создатель назвал ключ
  keyHash        String    @unique @map("key_hash") // bcrypt хеш токена
  keyPrefix      String    @map("key_prefix") // первые 8 символов для отображения
  scope          String    @default("READ") // READ | WRITE
  expiresAt      DateTime? @map("expires_at")
  lastUsedAt     DateTime? @map("last_used_at")
  revokedAt      DateTime? @map("revoked_at")
  createdById    String?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("api_keys")
}

model Organization {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  legalType           String?   @map("legal_type")
  legalName           String?   @map("legal_name")
  shortName           String?   @map("short_name")
  // Логотип организации (data-URL ~до 200КБ): брендирование сайдбара.
  // Если не задан — показывается логотип Commrent.
  logoUrl             String?   @map("logo_url")
  bin                 String?
  iin                 String?
  directorName        String?   @map("director_name")
  directorPosition    String?   @map("director_position")
  basis               String?
  legalAddress        String?   @map("legal_address")
  actualAddress       String?   @map("actual_address")
  bankName            String?   @map("bank_name")
  iik                 String?
  bik                 String?
  secondBankName      String?   @map("second_bank_name")
  secondIik           String?   @map("second_iik")
  secondBik           String?   @map("second_bik")
  kbe                 String?
  knp                 String?
  phone               String?
  email               String?
  isActive            Boolean   @default(true) @map("is_active")
  isSuspended         Boolean   @default(false) @map("is_suspended")
  approvalStatus      String    @default("APPROVED") @map("approval_status")
  approvalRequestedAt DateTime? @map("approval_requested_at")
  approvedAt          DateTime? @map("approved_at")
  approvedById        String?   @map("approved_by_id")
  rejectionReason     String?   @map("rejection_reason")
  ownerUserId         String?   @map("owner_user_id")
  planId              String?   @map("plan_id")
  planExpiresAt       DateTime? @map("plan_expires_at")
  isFoundersMember    Boolean   @default(false) @map("is_founders_member")
  foundersLockedPct   Int?      @default(0) @map("founders_locked_pct")
  foundersJoinedAt    DateTime? @map("founders_joined_at")
  foundersSlotNumber  Int?      @map("founders_slot_number")
  // НДС: для арендодателя — выставляются ли документы с НДС
  isVatPayer          Boolean   @default(false) @map("is_vat_payer")
  vatRate             Float     @default(16) @map("vat_rate")
  vatNumber           String?   @map("vat_number")
  // Пеня по умолчанию для новых договоров (% от просроченной суммы за день).
  // Подставляется в {penalty_percent} в шаблоне. У каждого Tenant может быть свой
  // penaltyPercent — он переопределяет это значение.
  defaultPenaltyPercent Float   @default(0.5) @map("default_penalty_percent")
  // Org-level флаги, переключаемые владельцем (JSON). Напр. additionalChargesDisabled.
  features            String    @default("{}")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  plan          Plan?          @relation(fields: [planId], references: [id])
  buildings     Building[]
  users         User[]
  subscriptions Subscription[]
  cashAccounts  CashAccount[]
  apiKeys       ApiKey[]
  faqArticles   FaqArticle[]
  storedFiles   StoredFile[]
  addons        OrganizationAddon[]
  services      OrganizationService[]
  esfConfig     OrgEsfConfig?

  @@index([approvalStatus, createdAt])
  @@index([isActive, approvalStatus])
  @@map("organizations")
}

// Реквизиты интеграции с ИС ЭСФ (КГД) — СВОИ у каждой организации (мультиорг).
// Секреты (пароль учётки, PIN контейнера) шифруются (lib/secret-crypto).
// Ключ .p12: v1 — файл на VPS, путь в certPath; самообслуживание (шифр-байты
// в certData + VPS-обёртка) — следующая фаза.
model OrgEsfConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique @map("organization_id")
  enabled        Boolean  @default(false)
  // Логин/пароль УЧЁТКИ ИС ЭСФ (WS-Security UsernameToken). НЕ пароль ЭЦП.
  wsUsername     String?  @map("ws_username")
  wsPasswordEnc  String?  @map("ws_password_enc")
  // ИИН физлица-владельца ключа (для createAuthTicket). Для ИП = ИИН ИП.
  signerIin      String?  @map("signer_iin")
  // Код ГСВС услуги (обязателен в АВР, поле work/gsvsCode). Специфичен для услуги
  // (напр. аренда), задаётся бухгалтером. Формат: NN.NN.NN.NN-NNNNNNNNNN.
  esfGsvsCode    String?  @map("esf_gsvs_code")
  // PIN контейнера .p12 (шифр).
  certPinEnc     String?  @map("cert_pin_enc")
  // Путь к .p12 на VPS-подписанте (v1). null = брать из env (bootstrap-орг).
  certPath       String?  @map("cert_path")
  // Загруженный из кабинета .p12 (base64, шифр) + имя файла. Если задан —
  // используется вместо certPath (самообслуживание; VPS-подписант принимает
  // ключ байтами). Контейнер сам по себе защищён PIN-ом.
  certDataEnc    String?  @map("cert_data_enc")
  certFileName   String?  @map("cert_file_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_esf_configs")
}

model AddressCache {
  id          String   @id @default(cuid())
  countryCode String   @default("kz") @map("country_code")
  queryKey    String   @map("query_key")
  displayName String   @map("display_name")
  region      String?
  city        String?
  settlement  String?
  street      String?
  houseNumber String?  @map("house_number")
  postcode    String?
  latitude    Float?
  longitude   Float?
  source      String   @default("PHOTON")
  sourceId    String?  @map("source_id")
  raw         Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([source, sourceId])
  @@index([countryCode, queryKey])
  @@index([countryCode, city])
  @@map("address_cache")
}

model WebVitalMetric {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  userId         String?  @map("user_id")
  name           String
  value          Float
  rating         String?
  delta          Float?
  navigationType String?  @map("navigation_type")
  path           String?
  url            String?
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, name, createdAt])
  @@index([name, createdAt])
  @@index([path, name, createdAt])
  @@map("web_vital_metrics")
}

model ServerPerformanceLog {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  userId         String?  @map("user_id")
  route          String
  step           String?
  kind           String   @default("ROUTE")
  durationMs     Int      @map("duration_ms")
  status         String   @default("ok")
  error          String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, route, createdAt])
  @@index([route, createdAt])
  @@index([kind, createdAt])
  @@index([status, createdAt])
  @@index([durationMs, createdAt])
  @@map("server_performance_logs")
}

// Денежные счета организации (банковские счета, касса, карты).
// Используются для отслеживания баланса (сколько денег где).
model FaqArticle {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  slug           String
  audience       String
  category       String
  question       String
  answer         String
  steps          String?
  tags           String?
  href           String?
  hrefLabel      String?  @map("href_label")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId, audience, isActive, sortOrder])
  @@map("faq_articles")
}

model CashAccount {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String // "Каспи Банк", "Касса", "Halyk Business"
  type           String // BANK | CASH | CARD
  balance        Float    @default(0)
  currency       String   @default("KZT")
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions CashTransaction[]

  @@index([organizationId])
  @@map("cash_accounts")
}

// Транзакции по денежным счетам (приход/расход/корректировка).
model CashTransaction {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  amount      Float // Положительное = приход, отрицательное = расход
  type        String // DEPOSIT | WITHDRAW | ADJUSTMENT | TRANSFER_OUT | TRANSFER_IN
  description String?
  date        DateTime @default(now())
  createdById String?  @map("created_by_id")
  // Опциональная связь с другими сущностями
  paymentId   String?  @map("payment_id")
  expenseId   String?  @map("expense_id")
  createdAt   DateTime @default(now()) @map("created_at")

  account CashAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, date])
  @@map("cash_transactions")
}

model Plan {
  id                  String   @id @default(cuid())
  code                String   @unique
  name                String
  description         String?
  priceMonthly        Float    @default(0) @map("price_monthly")
  priceYearly         Float    @default(0) @map("price_yearly")
  maxBuildings        Int?     @map("max_buildings")
  maxTenants          Int?     @map("max_tenants")
  maxUsers            Int?     @map("max_users")
  maxLeads            Int?     @map("max_leads")
  maxAreaSqm          Int?     @map("max_area_sqm")
  maxStorageGb        Int?     @map("max_storage_gb")
  foundersDiscountPct Int?     @default(40) @map("founders_discount_pct")
  discountStackCapPct Int?     @default(50) @map("discount_stack_cap_pct")
  features            String   @default("{}") // JSON
  isActive            Boolean  @default(true) @map("is_active")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")

  organizations Organization[]
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String    @id @default(cuid())
  organizationId     String    @map("organization_id")
  planId             String    @map("plan_id")
  startedAt          DateTime  @default(now()) @map("started_at")
  expiresAt          DateTime  @map("expires_at")
  status             String    @default("ACTIVE")
  paidAmount         Float     @default(0) @map("paid_amount")
  paymentMethod      String?   @map("payment_method")
  notes              String?
  billingPeriodCode  String?   @default("monthly") @map("billing_period_code")
  monthsCount        Int?      @default(1) @map("months_count")
  basePriceMonthly   Float?    @map("base_price_monthly")
  pricePerMonthPaid  Float?    @map("price_per_month_paid")
  discountBreakdown  String?   @map("discount_breakdown") // JSON
  autoRenew          Boolean   @default(false) @map("auto_renew")
  reminderSentAt     DateTime? @map("reminder_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@map("subscriptions")
}

// Периоды биллинга (помесячно, квартал, полугодие, год, 2 года) со скидкой.
model BillingPeriod {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  monthsCount  Int      @map("months_count")
  discountPct  Int      @default(0) @map("discount_pct")
  bonusMessage String?  @map("bonus_message")
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")

  @@map("billing_periods")
}

// Аддоны, купленные сверх тарифа (+здание, +арендаторы, +ГБ, +юзер и т.д.).
model OrganizationAddon {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  addonCode      String    @map("addon_code")
  quantity       Int       @default(1)
  priceMonthly   Float     @default(0) @map("price_monthly")
  isActive       Boolean   @default(true) @map("is_active")
  startedAt      DateTime  @default(now()) @map("started_at")
  expiresAt      DateTime? @map("expires_at")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@index([addonCode])
  @@map("organization_addons")
}

// Разовые услуги (онбординг, юр.пакет, миграция Excel, интеграция 1С).
model OrganizationService {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  serviceCode    String    @map("service_code")
  serviceName    String    @map("service_name")
  price          Float
  status         String    @default("PENDING") // PENDING | PAID | DELIVERED | CANCELLED
  paidAt         DateTime? @map("paid_at")
  deliveredAt    DateTime? @map("delivered_at")
  paymentMethod  String?   @map("payment_method")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("organization_services")
}

// Singleton-состояние программы Founders (всего 15 слотов, сколько занято и т.п.).
model FoundersProgramState {
  id          String    @id @default("singleton")
  totalSlots  Int       @default(15) @map("total_slots")
  takenSlots  Int       @default(0) @map("taken_slots")
  discountPct Int       @default(40) @map("discount_pct")
  endsAt      DateTime? @map("ends_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("founders_program_state")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String // CONTRACT_EXPIRING | PAYMENT_DUE | NEW_REQUEST | NEW_COMPLAINT | INFO
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Building {
  id                    String   @id @default(cuid())
  organizationId        String   @map("organization_id")
  name                  String
  address               String
  // Адрес для документов (договоры/акты). Если пуст — используется обычный
  // `address`. Нужен потому что геокодер часто возвращает адрес на казахском
  // («Шығыс Қазақстан облысы»), а в договоры нужно по-русски.
  documentAddress       String?  @map("document_address")
  addressCountryCode    String?  @map("address_country_code")
  addressRegion         String?  @map("address_region")
  addressCity           String?  @map("address_city")
  addressSettlement     String?  @map("address_settlement")
  addressStreet         String?  @map("address_street")
  addressHouseNumber    String?  @map("address_house_number")
  addressPostcode       String?  @map("address_postcode")
  addressLatitude       Float?   @map("address_latitude")
  addressLongitude      Float?   @map("address_longitude")
  addressSource         String?  @map("address_source")
  addressSourceId       String?  @map("address_source_id")
  description           String?
  phone                 String?
  email                 String?
  responsible           String?
  // Администратор здания — User с ролью ADMIN, к которому идут все вопросы по аренде.
  // Иерархия: Owner → Administrator → Tenants.
  administratorUserId   String?  @map("administrator_user_id")
  totalArea             Float?   @map("total_area")
  // Per-building нумерация документов: префикс — настраиваемый (например, F16),
  // счётчик инкрементируется при подтверждении номера. Уникальность контролируется
  // в пределах здания на текущий год.
  contractPrefix        String?  @map("contract_prefix")
  contractCounter       Int      @default(0) @map("contract_counter")
  invoicePrefix         String?  @map("invoice_prefix")
  invoiceCounter        Int      @default(0) @map("invoice_counter")
  actPrefix             String?  @map("act_prefix")
  actCounter            Int      @default(0) @map("act_counter")
  reconciliationPrefix  String?  @map("reconciliation_prefix")
  reconciliationCounter Int      @default(0) @map("reconciliation_counter")
  isActive              Boolean  @default(true) @map("is_active")
  // Эксплуатационный сбор (Приложение №3 к договору) — сезонные тарифы
  // на квадратный метр в месяц. Зимний период (по умолчанию окт-апр)
  // обычно выше из-за отопления, летний — ниже.
  serviceFeeWinterRate    Float?  @map("service_fee_winter_rate")
  serviceFeeSummerRate    Float?  @map("service_fee_summer_rate")
  // Массив номеров месяцев (1..12), которые считаются зимними.
  // По умолчанию [10,11,12,1,2,3,4]. Хранится как JSON-строка для совместимости
  // с провайдерами без array-типа; пустое значение = дефолт.
  serviceFeeWinterMonths  String? @map("service_fee_winter_months")
  // Процент годовой индексации (по умолчанию 10). Применяется в cron-задаче
  // ежедневно: если now ≥ serviceFeeLastIndexedAt + 1 год — ставки ×(1+pct/100).
  serviceFeeIndexationPct Float?  @default(10) @map("service_fee_indexation_pct")
  serviceFeeLastIndexedAt DateTime? @map("service_fee_last_indexed_at")
  // Какие коммунальные услуги УЖЕ включены в эксплуатационный сбор —
  // не выставляются арендатору отдельной строкой и скрываются из формы
  // «Доп. начисления». JSON-массив строк: ["ELECTRICITY","WATER","GARBAGE"...].
  // Пусто = все услуги выставляются отдельно. Добавлено 2026-05-27.
  utilitiesInServiceFee   String? @map("utilities_in_service_fee")
  createdAt             DateTime @default(now()) @map("created_at")

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  administrator     User?                @relation("BuildingAdmin", fields: [administratorUserId], references: [id], onDelete: SetNull)
  floors            Floor[]
  emergencyContacts EmergencyContact[]
  expenses          Expense[]
  recurringExpenses RecurringExpense[]
  tariffs           Tariff[]
  tasks             Task[]
  leads             Lead[]
  userAccess        UserBuildingAccess[]
  storedFiles       StoredFile[]
  directTenants     Tenant[]             @relation("BuildingDirectTenants")
  decor             BuildingDecor[]

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, addressCity])
  @@index([organizationId, addressStreet])
  @@map("buildings")
}

// Декор территории/крыши: деревья, кусты, фонари, скамейки — чистая сцена,
// не сдаётся в аренду (в отличие от Space kind=OBJECT). Позиция (x,z) в метрах
// в мировых координатах сцены (центр здания = 0,0), rot — градусы.
model BuildingDecor {
  id         String   @id @default(cuid())
  buildingId String   @map("building_id")
  kind       String // tree|bush|grass|flowerbed|wall|fence|gate|door|stairs|bench|lamp|bin|canopy|hvac|vent|tank|table|chair|cabinet
  x          Float    @default(0)
  z          Float    @default(0)
  rot        Float    @default(0)
  scale      Float    @default(1)
  // Для kind="wallrun" — длина нарисованной стены в метрах (0 для прочих).
  len        Float    @default(0)
  // Уровень: "ground" (земля/территория) | "roof" (крыша) | <floorId> (этаж).
  level      String   @default("ground")
  // Для kind="custom" — ссылка на импортированную модель GLB (/api/storage/<id>).
  modelUrl   String?  @map("model_url")
  // Устаревшее: true — на крыше (мигрировано в level="roof").
  onRoof     Boolean  @default(false) @map("on_roof")
  createdAt  DateTime @default(now()) @map("created_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@map("building_decor")
}

model UserBuildingAccess {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  buildingId String   @map("building_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([userId, buildingId])
  @@index([buildingId])
  @@map("user_building_access")
}

model Tariff {
  id          String   @id @default(cuid())
  buildingId  String   @map("building_id")
  type        String // ELECTRICITY | WATER | HEATING | GARBAGE | INTERNET | OTHER
  name        String
  rate        Float
  unit        String   @default("ед.")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, isActive])
  @@map("tariffs")
}

model Floor {
  id                String  @id @default(cuid())
  buildingId        String  @map("building_id")
  number            Int
  name              String
  // FLOOR — обычный этаж здания; TERRITORY — прилегающая территория (двор,
  // парковка, открытые площадки). Территория сдаётся теми же Space, но её
  // площадь не входит в площадь здания.
  kind              String  @default("FLOOR")
  ratePerSqm        Float   @default(0) @map("rate_per_sqm")
  totalArea         Float?  @map("total_area")
  layoutJson        String? @map("layout_json")
  fixedMonthlyRent  Float?  @map("fixed_monthly_rent")
  fullFloorTenantId String? @map("full_floor_tenant_id")

  building        Building @relation(fields: [buildingId], references: [id])
  spaces          Space[]
  fullFloorTenant Tenant?  @relation("FullFloorTenant", fields: [fullFloorTenantId], references: [id])

  @@index([buildingId, number])
  @@index([fullFloorTenantId])
  @@map("floors")
}

model Space {
  id          String  @id @default(cuid())
  floorId     String  @map("floor_id")
  number      String
  area        Float
  status      String  @default("VACANT")
  // RENTABLE = арендопригодное помещение (можно сдать)
  // COMMON = общая зона: коридор, лестница, санузел, тех. помещение —
  // не сдаётся, не считается в заполняемости, не появляется в списке свободных.
  kind        String  @default("RENTABLE")
  description String?
  // Фото помещения: JSON-массив сжатых data-URL (на клиенте ужимаются до ~1280px).
  // Показываются в карточке, попапе плана и на публичной витрине свободных площадей.
  photos      String? @map("photos")
  // Позиция объекта зоны (крыша/территория) в метрах внутри зоны. NULL = авто-сетка.
  // Используется 3D-видом, чтобы объект стоял там, где его поставили.
  posX        Float?  @map("pos_x")
  posZ        Float?  @map("pos_z")
  // Поворот объекта зоны (градусы вокруг вертикали) для 3D. NULL = 0°.
  posRot      Float?  @map("pos_rot")

  floor        Floor         @relation(fields: [floorId], references: [id])
  tenant       Tenant?
  tenantSpaces TenantSpace[]
  meters       Meter[]

  @@index([floorId, status])
  @@index([floorId, kind])
  @@map("spaces")
}

model Tenant {
  id               String    @id @default(cuid())
  userId           String    @unique @map("user_id")
  spaceId          String?   @unique @map("space_id")
  // Прямая привязка к зданию для арендаторов БЕЗ помещения («крышные»: вышки
  // Beeline/Altel, камеры Сергек — на крыше, платят аренду, но не занимают space).
  // Для обычных арендаторов здание выводится через space/tenantSpaces/fullFloors.
  buildingId       String?   @map("building_id")
  // Описание размещения для арендаторов без помещения («Крыша — антенно-мачтовое
  // сооружение Beeline»). Показывается вместо колонки «Помещение».
  placementNote    String?   @map("placement_note")
  companyName      String    @map("company_name")
  bin              String?
  iin              String?
  bankName         String?   @map("bank_name")
  iik              String?
  bik              String?
  legalType        String    @default("IP") @map("legal_type")
  category         String?
  legalAddress     String?   @map("legal_address")
  actualAddress    String?   @map("actual_address")
  directorName     String?   @map("director_name")
  directorPosition String?   @map("director_position")
  // Целевое использование помещения — что арендатор у нас делает («розничная
  // торговля продуктами», «офис ЧСИ», «салон красоты»). Подставляется в
  // пункт 1.1 договора через placeholder {tenant_use_purpose}.
  usePurpose       String?   @map("use_purpose")
  needsCleaning    Boolean   @default(false) @map("needs_cleaning")
  cleaningFee      Float     @default(0) @map("cleaning_fee")
  customRate       Float?    @map("custom_rate")
  fixedMonthlyRent Float?    @map("fixed_monthly_rent")
  contractStart    DateTime? @map("contract_start")
  contractEnd      DateTime? @map("contract_end")
  // Фактическая дата заселения. Может отличаться от contractStart: договор
  // подписан 1 апреля, заехал 1 мая. Если NULL — = contractStart.
  // Используется как точка отсчёта каникул и proration. Добавлено 2026-05-27.
  moveInDate       DateTime? @map("move_in_date")
  // Арендные каникулы — N месяцев после moveInDate без начисления аренды
  // (ремонт, заселение). Cron check-deadlines пропускает создание Charge
  // для этих периодов. По умолчанию 0.
  rentFreeMonths   Int       @default(0) @map("rent_free_months")
  // Гарантийный депозит — сумма, внесённая арендатором в начале договора
  // и возвращаемая при выселении. По умолчанию = monthlyRent (1 месяц аренды),
  // но владелец может задать явно. Подставляется в {deposit_amount} шаблона.
  depositAmount    Float?    @map("deposit_amount")
  paymentDueDay    Int       @default(10) @map("payment_due_day")
  // Освобождён от эксплуатационного сбора здания: если true — строка
  // «Эксплуатационные расходы» НЕ добавляется ни в авто-начисления (cron),
  // ни в счёт/АВР/ЭСФ по договору. Сбор настраивается на здании, это
  // per-tenant исключение. Добавлено 2026-06-16.
  serviceFeeExempt Boolean   @default(false) @map("service_fee_exempt")
  // Пеня за просрочку платежей (% за день). Default 0.5 (изменён с 1
  // 2026-05-26 — пересмотр шаблона). Если null — наследуется
  // organization.defaultPenaltyPercent.
  penaltyPercent   Float     @default(0.5) @map("penalty_percent")
  // Документ-основание для подписи (для ИП — «Уведомления № X от Y»,
  // для ТОО — «Устава» уже подставляется автоматически). Подставляется
  // в {tenant_basis_document}. Если пусто — fallback по legalType.
  basisDocument    String?   @map("basis_document")
  // Удостоверение личности — для арендатора-ФИЗЛИЦА (legalType=PHYSICAL): у него
  // нет БИН/устава, основание в договоре — паспортные данные. Добавлено 2026-06-17.
  idDocNumber      String?   @map("id_doc_number")
  idDocIssuedBy    String?   @map("id_doc_issued_by")
  idDocIssuedAt    DateTime? @map("id_doc_issued_at")
  idDocExpiresAt   DateTime? @map("id_doc_expires_at")
  // Является ли арендатор плательщиком НДС (для будущей ЭСФ)
  isVatPayer       Boolean   @default(false) @map("is_vat_payer")
  vatRate          Float     @default(16) @map("vat_rate")
  // Выставлять ли этому арендатору ЭСФ (счёт-фактуру в КГД). Физлицам обычно
  // не выставляется — флаг управляется в карточке. Добавлено 2026-06-17.
  esfEnabled       Boolean   @default(true) @map("esf_enabled")
  // Чёрный список: причина и время попадания. Если != null — нельзя завести
  // нового арендатора с таким БИН/ИИН (предупреждение администратору).
  blacklistedAt    DateTime? @map("blacklisted_at")
  blacklistReason  String?   @map("blacklist_reason")
  // Внутренние заметки владельца/админа («позвонил 5-го, обещал оплатить»).
  // Арендатору НЕ видны нигде.
  internalNotes    String?   @map("internal_notes")
  // Индексация аренды: ежегодное повышение ставки на N % (ст. договора).
  // Cron в дату nextIndexationAt повышает customRate/fixedMonthlyRent на
  // indexationPct и сдвигает дату на год вперёд. NULL — индексации нет.
  indexationPct    Float?    @map("indexation_pct")
  nextIndexationAt DateTime? @map("next_indexation_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  user           User                @relation(fields: [userId], references: [id])
  space          Space?              @relation(fields: [spaceId], references: [id])
  building         Building?           @relation("BuildingDirectTenants", fields: [buildingId], references: [id], onDelete: SetNull)
  tenantSpaces     TenantSpace[]
  charges          Charge[]
  payments         Payment[]
  paymentReports   PaymentReport[]
  contracts        Contract[]
  installmentPlans DebtInstallmentPlan[]
  documents      TenantDocument[]
  storedFiles    StoredFile[]
  requests       Request[]
  fullFloors     Floor[]             @relation("FullFloorTenant")
  bankAccounts   TenantBankAccount[]

  // userId уже @unique → индекс есть автоматически. Не дублируем.
  // createdAt — для orderBy в /admin/tenants (DESC).
  @@index([createdAt(sort: Desc)])
  @@index([deletedAt])
  @@index([buildingId])
  @@map("tenants")
}

model TenantBankAccount {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  label     String?
  bankName  String   @map("bank_name")
  iik       String
  bik       String
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, iik])
  @@index([tenantId, isPrimary])
  @@map("tenant_bank_accounts")
}

model TenantSpace {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  spaceId   String   @map("space_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  space  Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, spaceId])
  @@unique([spaceId])
  @@index([tenantId])
  @@map("tenant_spaces")
}

model Staff {
  id       String   @id @default(cuid())
  userId   String   @unique @map("user_id")
  position String
  salary   Float    @default(0)
  hireDate DateTime @default(now()) @map("hire_date")

  user           User            @relation(fields: [userId], references: [id])
  salaryPayments SalaryPayment[]

  @@map("staff")
}

model Contract {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  number             String
  type               String    @default("STANDARD")
  content            String
  // Workflow статусы:
  // DRAFT → SENT → VIEWED → SIGNED_BY_TENANT → SIGNED (обе стороны)
  // или альтернативные: REJECTED, EXPIRED
  status             String    @default("DRAFT")
  signedAt           DateTime? @map("signed_at")
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  // Workflow подписания:
  signToken          String?   @unique @map("sign_token") // токен для уникальной ссылки tenant'у
  sentAt             DateTime? @map("sent_at") // когда отправлено арендатору
  viewedAt           DateTime? @map("viewed_at") // когда арендатор открыл ссылку
  signedByTenantAt   DateTime? @map("signed_by_tenant_at")
  signedByTenantName String?   @map("signed_by_tenant_name") // ФИО подписавшего
  signedByLandlordAt DateTime? @map("signed_by_landlord_at")
  rejectedAt         DateTime? @map("rejected_at")
  rejectionReason    String?   @map("rejection_reason")
  parentContractId   String?   @map("parent_contract_id")
  changeKind         String?   @map("change_kind")
  changePayload      Json?     @map("change_payload")
  effectiveDate      DateTime? @map("effective_date")
  appliedAt          DateTime? @map("applied_at")
  // Версионирование: при создании новой версии контракт-предок переходит в ARCHIVED,
  // а на новой записи version = parent.version + 1, parentVersionId указывает на источник.
  version            Int       @default(1)
  parentVersionId    String?   @map("parent_version_id")
  // Снимок ContractState из конструктора (для перерисовки DOCX с QR после подписи).
  builderState       Json?     @map("builder_state")
  // Внешний договор (type=EXTERNAL): загруженный PDF контрагента (вышки/камеры,
  // которые не принимают нашу редакцию). Подписан офлайн, конструктор/ЭЦП не нужны.
  attachmentFileId   String?   @unique @map("attachment_file_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  deletedAt          DateTime? @map("deleted_at")

  tenant         Tenant     @relation(fields: [tenantId], references: [id])
  attachmentFile StoredFile? @relation("ContractAttachment", fields: [attachmentFileId], references: [id], onDelete: SetNull)
  parentContract Contract?  @relation("ContractAddenda", fields: [parentContractId], references: [id], onDelete: SetNull)
  addenda        Contract[] @relation("ContractAddenda")
  parentVersion  Contract?  @relation("ContractVersions", fields: [parentVersionId], references: [id], onDelete: SetNull)
  versions       Contract[] @relation("ContractVersions")
  charges        Charge[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, type, status, createdAt])
  @@index([parentContractId])
  @@index([parentVersionId])
  @@index([changeKind, appliedAt])
  @@index([deletedAt])
  @@map("contracts")
}

model Charge {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  // Опциональная связь с контрактом-источником начисления. При расторжении/архивации
  // договора charge не удаляется (исторические данные нужны для отчётов), просто
  // contractId зануляется (ON DELETE SET NULL).
  contractId  String?   @map("contract_id")
  period      String
  type        String
  amount      Float
  description String?
  isPaid      Boolean   @default(false) @map("is_paid")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  // Пеня по этому начислению отменена вручную админом (см. waivePenalty). Cron
  // check-deadlines пропускает такие начисления и больше не капает по ним пеню —
  // полезно пока нет онлайн-оплаты и загрузки подтверждения платежа.
  penaltyWaived Boolean @default(false) @map("penalty_waived")
  // Если начисление реструктуризовано в рассрочку — ссылка на план. Пока план
  // ACTIVE, пеня по такому начислению не начисляется (cron check-deadlines). При
  // срыве плана (просрочен платёж) поле зануляется и пеня возобновляется.
  installmentPlanId String? @map("installment_plan_id")

  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  contract        Contract?            @relation(fields: [contractId], references: [id], onDelete: SetNull)
  installmentPlan DebtInstallmentPlan? @relation(fields: [installmentPlanId], references: [id], onDelete: SetNull)

  @@index([tenantId, isPaid, dueDate])
  @@index([tenantId, period, type])
  @@index([installmentPlanId])
  @@index([dueDate])
  // Календарь / dashboard часто фильтруют { tenantId, dueDate: { gte, lt } } без isPaid —
  // существующий [tenantId, isPaid, dueDate] для этого пути теряет dueDate-селективность.
  @@index([tenantId, dueDate])
  @@index([contractId])
  @@index([deletedAt])
  // Unique constraint via migration 020 (partial index, WHERE deleted_at IS NULL).
  // Prisma `@@unique` не поддерживает partial — добавляем raw SQL чтобы
  // soft-delete + recreate не ломал constraint.
  @@map("charges")
}

// Рассрочка по долгу: реструктуризация просроченной задолженности арендатора в
// график платежей. Пока план ACTIVE, по покрытым начислениям не капает пеня.
// При срыве (просрочен и не оплачен платёж) cron переводит план в BROKEN и
// возвращает начисления под пеню.
model DebtInstallmentPlan {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  totalAmount Float    @map("total_amount")
  // ACTIVE | COMPLETED | BROKEN | CANCELLED
  status      String   @default("ACTIVE")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  installments DebtInstallment[]
  charges      Charge[]

  @@index([tenantId, status])
  @@map("debt_installment_plans")
}

model DebtInstallment {
  id        String    @id @default(cuid())
  planId    String    @map("plan_id")
  seq       Int // порядковый номер платежа 1..N
  dueDate   DateTime  @map("due_date")
  amount    Float
  isPaid    Boolean   @default(false) @map("is_paid")
  paidAt    DateTime? @map("paid_at")
  // Платёж, которым закрыт взнос (для трассировки). Не FK — как в cash_transactions.
  paymentId String?   @map("payment_id")
  createdAt DateTime  @default(now()) @map("created_at")

  plan DebtInstallmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, seq])
  @@index([isPaid, dueDate])
  @@map("debt_installments")
}

model Payment {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  amount      Float
  paymentDate DateTime  @map("payment_date")
  method      String    @default("TRANSFER")
  note        String?
  // Нераспределённый остаток платежа (аванс/переплата): FIFO гасит начисления только
  // целиком, остаток хранится здесь и автоматически закрывает следующие начисления
  // (lib/tenant-credit.ts). Раньше остаток «терялся» (аудит 2026-06-10, п.5).
  unappliedAmount Float @default(0) @map("unapplied_amount")
  // Идентификатор из внешней системы (Kaspi txnId, импортированная строка
  // банковской выписки и т.п.) для идемпотентности webhook'ов / повторных импортов.
  externalRef String?   @unique @map("external_ref")
  createdAt   DateTime  @default(now()) @map("created_at")
