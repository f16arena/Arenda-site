// Кастомный шаблон документа на уровне организации.
// На каждый тип (CONTRACT / INVOICE / ACT / RECONCILIATION) хранится один
// активный шаблон (предыдущие — деактивированные, для истории).
// DOCX (через docxtemplater) и XLSX (через ExcelJS) — для генерации.
// PDF — только как образец-превью, не для подстановки.
model DocumentTemplate {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  documentType   String   @map("document_type")
  format         String
  fileName       String   @map("file_name")
  fileBytes      Bytes    @map("file_bytes")
  fileSize       Int      @map("file_size")
  isActive       Boolean  @default(true) @map("is_active")
  uploadedById   String?  @map("uploaded_by_id")
  uploadedAt     DateTime @default(now()) @map("uploaded_at")
  notes          String?

  @@index([organizationId, documentType, isActive])
  @@map("document_templates")
}

// Архив сгенерированных документов — для повторного скачивания и фильтра.
model GeneratedDocument {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  documentType   String   @map("document_type")
  number         String?
  tenantId       String?  @map("tenant_id")
  tenantName     String   @map("tenant_name")
  period         String?
  totalAmount    Float?   @map("total_amount")
  fileName       String   @map("file_name")
  fileBytes      Bytes    @map("file_bytes")
  fileSize       Int      @map("file_size")
  format         String   @default("DOCX")
  generatedById  String?   @map("generated_by_id")
  generatedAt    DateTime  @default(now()) @map("generated_at")
  templateUsedId String?   @map("template_used_id")
  deletedAt      DateTime? @map("deleted_at")
  // Договор-источник: счёт/АВР/сверка выписаны по нему (номер, дата, суммы).
  // Жёсткая связь для «дерева документов» арендатора и ссылок ЭСФ.
  contractId     String?   @map("contract_id")
  // Интеграция с ИС ЭСФ (КГД): id и рег. номер в госсистеме + статус
  esfId          String?   @map("esf_id")
  esfRegNumber   String?   @map("esf_reg_number")
  esfStatus      String?   @map("esf_status") // SENT | DELIVERED | CONFIRMED | DECLINED | CANCELED | FAILED
  esfSentAt      DateTime? @map("esf_sent_at")
  esfError       String?   @map("esf_error")
  // Сверка взаиморасчётов: статус подтверждения контрагентом (только для
  // documentType = RECONCILIATION). SENT — отправлен арендатору на сверку,
  // AGREED — арендатор подтвердил, DISPUTED — заявил расхождение (с комментарием).
  reconStatus       String?   @map("recon_status")
  reconRespondedAt  DateTime? @map("recon_responded_at")
  reconResponseNote String?   @map("recon_response_note")

  @@index([organizationId, documentType])
  @@index([organizationId, documentType, generatedAt])
  @@index([organizationId, generatedAt])
  @@index([organizationId, period])
  @@index([tenantId])
  @@index([tenantId, generatedAt])
  // Mobile + cabinet часто запрашивают { organizationId, tenantId } для документов
  // конкретного арендатора — отдельный индекс на (tenantId) есть, но composite быстрее
  // когда запрос ещё и фильтрует по organizationId.
  @@index([organizationId, tenantId])
  @@index([deletedAt])
  @@index([contractId])
  @@map("generated_documents")
}

// Хранилище ЭЦП-подписей документов через NCALayer (НУЦ РК).
// Один документ может быть подписан несколькими сторонами (арендодатель + арендатор).
model DocumentSignature {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  documentType   String    @map("document_type") // CONTRACT | INVOICE | ACT | RECONCILIATION | HANDOVER
  documentId     String?   @map("document_id")
  documentRef    String?   @map("document_ref")
  signerUserId   String?   @map("signer_user_id")
  signerName     String    @map("signer_name")
  signerIin      String?   @map("signer_iin")
  signerOrgBin   String?   @map("signer_org_bin")
  signedHashB64  String    @map("signed_hash_b64")
  signatureB64   String    @map("signature_b64")
  certPemB64     String    @map("cert_pem_b64")
  validFrom      DateTime? @map("valid_from")
  validTo        DateTime? @map("valid_to")
  algorithm      String    @default("RSA-SHA256") @map("algorithm")
  // Метка доверенного времени (TSP, RFC 3161) от TSA НУЦ РК — извлекается из CMS
  // при верификации через NCANode. Доказывает момент подписания независимо от часов клиента.
  tspGenTime     DateTime? @map("tsp_gen_time")
  tspSerial      String?   @map("tsp_serial")
  signedAt       DateTime  @default(now()) @map("signed_at")

  @@index([organizationId])
  @@index([documentType, documentId])
  @@map("document_signatures")
}

// Токены для верификации email/телефона + сброса пароля.
