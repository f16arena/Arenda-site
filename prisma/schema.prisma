  buildingId     String    @map("building_id")
  createdById    String?   @map("created_by_id")
  type           String    @default("INFO")
  severity       String    @default("INFO")
  title          String
  message        String
  startsAt       DateTime? @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([organizationId, buildingId, createdAt])
  @@index([buildingId, startsAt, endsAt])
  @@map("building_notices")
}

model DocumentSignatureRequest {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  requestedById   String?   @map("requested_by_id")
  recipientUserId String    @map("recipient_user_id")
  documentType    String    @map("document_type")
  documentId      String?   @map("document_id")
  documentRef     String?   @map("document_ref")
  title           String
  message         String?
  status          String    @default("PENDING")
  channel         String    @default("MOBILE")
  allowedMethods  Json?     @map("allowed_methods")
  preferredMethod String?   @map("preferred_method")
  signToken       String?   @unique @map("sign_token")
  expiresAt       DateTime? @map("expires_at")
  viewedAt        DateTime? @map("viewed_at")
  signedAt        DateTime? @map("signed_at")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?   @map("rejection_reason")
  signatureId     String?   @map("signature_id")
  smsPhoneMasked  String?   @map("sms_phone_masked")
  otpHash         String?   @map("otp_hash")
  otpExpiresAt    DateTime? @map("otp_expires_at")
  otpVerifiedAt   DateTime? @map("otp_verified_at")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([organizationId, status, createdAt])
  @@index([recipientUserId, status, createdAt])
  @@index([requestedById, createdAt])
  @@index([documentType, documentId])
  @@map("document_signature_requests")
}

// Черновик договора, собранный визуальным конструктором (lib/contract-engine).
// builderState — сериализованный ContractState (Json). Отдельная таблица: она НЕ
// модифицирует модель Contract — та остаётся источником для подписи/жизненного
// цикла; конструктор лишь готовит контент (см. docs/AUDIT, signing-контур).
model ContractDraft {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String    @default("Без названия")
  builderState   Json      @map("builder_state")
  tenantId       String?   @map("tenant_id")
  status         String    @default("DRAFT")
  createdById    String?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@index([organizationId, status, updatedAt])
  @@index([organizationId, tenantId])
  @@index([deletedAt])
  @@map("contract_drafts")
}

// Building Studio — проект 3D-модели здания (Babylon). doc — сериализованный
// BuilderDocument (Json/jsonb). revision — для оптимистичной блокировки автосейва.
model BuilderProject {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String   @default("Без названия")
  buildingId     String?  @map("building_id")
  doc            Json
  schemaVersion  Int      @default(1) @map("schema_version")
  revision       Int      @default(0)
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([organizationId, updatedAt])
  @@map("builder_projects")
}

// Черновик объявления для внешней площадки (krisha и т.п.). Полуавтомат: генерим
// текст/цену/фото из помещения, пользователь публикует на площадке. Связи — слабые
// (как BuilderProject), без FK: organization_id/space_id/building_id — обычные колонки.
model ListingDraft {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  buildingId     String?  @map("building_id")
  spaceId        String   @map("space_id")
  target         String   @default("krisha") // krisha|olx|other
  title          String
  description    String
  priceMonthly   Int?     @map("price_monthly")
  pricePerSqm    Int?     @map("price_per_sqm")
  status         String   @default("DRAFT") // DRAFT|COPIED|PUBLISHED|ARCHIVED
  externalUrl    String?  @map("external_url")
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([spaceId])
  @@map("listing_drafts")
}

// Read-only витрина по токену: token → проект (Showcase, публичный домен).
model BuilderShare {
  token     String   @id
  projectId String   @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@map("builder_shares")
}
