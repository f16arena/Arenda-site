  type      String // EMAIL_VERIFY | PHONE_VERIFY | PASSWORD_RESET | EMAIL_CHANGE | PHONE_CHANGE
  target    String // email или телефон
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, type])
  @@index([token])
  @@map("verification_tokens")
}

