{
  "name": "arenda-pro",
  "version": "1.3.148",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "node scripts/deploy-migrations.mjs && prisma generate && next build",
    "build:analyze": "node -e \"process.env.ANALYZE='true';require('child_process').execSync('next build',{stdio:'inherit',env:process.env})\"",
    "start": "next start",
    "lint": "eslint",
    "perf:audit": "node scripts/performance-audit.mjs",
    "security:audit": "node scripts/security-isolation-audit.mjs",
    "backfill:cash-link": "tsx scripts/backfill-cash-payment-link.ts",
    "ci:performance-gate": "node scripts/ci-performance-gate.mjs",
    "test:unit": "vitest run",
    "test:e2e:payment": "tsx scripts/e2e-critical-payment.ts",
    "test:e2e:cash": "tsx scripts/e2e-cash-balance.ts",
    "test:e2e:isolation": "tsx scripts/e2e-isolation.ts",
    "test:e2e:v3": "tsx scripts/e2e-v3-launch.ts",
    "test:e2e:web": "playwright test",
    "test:e2e:web:headed": "playwright test --headed",
    "test:e2e:web:report": "playwright show-report",
    "test:mobile:typecheck": "npm --prefix mobile run typecheck",
    "audit:site": "playwright test tests/e2e/full-site-audit.spec.ts --project=chromium-desktop --workers=1",
    "quality:audit": "npm run lint && npm run ci:performance-gate && npm run test:e2e:payment && npm run test:e2e:cash && npm run test:e2e:isolation"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@babylonjs/core": "^9.12.0",
    "@peculiar/asn1-cms": "^2.7.0",
    "@peculiar/asn1-schema": "^2.7.0",
    "@peculiar/asn1-x509": "^2.7.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.51.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "docxtemplater": "^3.68.6",
    "earcut": "^3.0.2",
    "exceljs": "^4.4.0",
    "fflate": "^0.8.3",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "otpauth": "^9.5.1",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.20.0",
    "pizzip": "^3.2.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/earcut": "^3.0.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
