<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<xs:schema version="1.0" targetNamespace="v2.esf" xmlns:tns="v2.esf" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:v2="v2.esf" xmlns:ns1="abstractInvoice.esf">

  <xs:import namespace="abstractInvoice.esf"/>

  <xs:element name="invoice" type="tns:InvoiceV2"/>

  <xs:complexType name="InvoiceV2">
    <xs:annotation>
      <xs:documentation>ЭСФ</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ns1:AbstractInvoice">
        <xs:sequence>
          <xs:element name="addInf" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Дополнительные сведения (K 43)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="consignee" type="tns:Consignee" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Реквизиты грузополучателя (D 24)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="consignor" type="tns:Consignor" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Реквизиты грузоотправителя (D 23)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="customerAgentAddress" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Реквизиты поверенного (оператора) покупателя. Адрес места нахождения (J 41)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="customerAgentDocDate" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Документ-Дата (J 42.2)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="customerAgentDocNum" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Документ-Номер (J 42.1)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="customerAgentName" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Реквизиты поверенного (оператора) покупателя. Поверенный (J 40)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="customerAgentTin" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Реквизиты поверенного (оператора) покупателя. БИН (J 39)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="customerParticipants" minOccurs="0">
            <xs:complexType>
              <xs:sequence>
                <xs:element name="participant" type="tns:Participant" maxOccurs="unbounded">
                  <xs:annotation>
                    <xs:documentation>Получатель (УСД) (H)</xs:documentation>
                  </xs:annotation>
                </xs:element>
              </xs:sequence>
            </xs:complexType>
          </xs:element>
          <xs:element name="customers">
            <xs:complexType>
              <xs:sequence>
                <xs:element name="customer" type="tns:Customer" maxOccurs="unbounded">
                  <xs:annotation>
                    <xs:documentation>Получатель (C)</xs:documentation>
                  </xs:annotation>
                </xs:element>
              </xs:sequence>
            </xs:complexType>
          </xs:element>
          <xs:element name="datePaper" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Дата выписки на бумажном носителе (2.1)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="deliveryDocDate" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Дата документа, подтверждающего поставку товаров (работ, услуг) (F 32.2)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="deliveryDocDate2" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Дата документа, подтверждающего поставку товаров (работ, услуг) (F 32.4)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="deliveryDocNum" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Номер документа, подтверждающего поставку товаров (работ, услуг) (F 32.1)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="deliveryDocNum2" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Номер документа, подтверждающего поставку товаров (работ, услуг) (F 32.3)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="deliveryTerm" type="tns:DeliveryTerm" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Условия поставки (E)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="productSet" type="tns:ProductSet" minOccurs="1">
            <xs:annotation>
              <xs:documentation>Товары (работы, услуги) (G)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="publicOffice" type="tns:PublicOffice" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Реквизиты государственного учреждения (F)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="reasonPaper" type="tns:PaperReasonType" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Причина выписки на бумажном носителе (2.1)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="sellerAgentAddress" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Адрес места нахождения (I 37)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="sellerAgentDocDate" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Документ-Дата (I 38.2)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="sellerAgentDocNum" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Документ-Номер (I 38.1)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="sellerAgentName" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Поверенный (I 36)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="sellerAgentTin" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>БИН (I 35)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="sellerParticipants" minOccurs="0">
            <xs:complexType>
              <xs:sequence>
                <xs:element name="participant" type="tns:Participant" maxOccurs="unbounded">
                  <xs:annotation>
                    <xs:documentation>Поставщик (УСД) (H)</xs:documentation>
                  </xs:annotation>
                </xs:element>
              </xs:sequence>
            </xs:complexType>
          </xs:element>
          <xs:element name="sellers">
            <xs:complexType>
              <xs:sequence>
                <xs:element name="seller" type="tns:Seller" maxOccurs="unbounded">
                  <xs:annotation>
                    <xs:documentation>Поставщик (B)</xs:documentation>
                  </xs:annotation>
                </xs:element>
              </xs:sequence>
            </xs:complexType>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="Consignee">
    <xs:annotation>
      <xs:documentation>Реквизиты грузополучателя (D 26)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="address" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Адрес (D 26.3)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="countryCode" type="xs:string" minOccurs="1">
        <xs:annotation>
          <xs:documentation>Код страны (D 26.4)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="name" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Наименование (D 26.2)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="tin" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>ИИН/БИН (D 26.1)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="Consignor">
    <xs:annotation>
      <xs:documentation>Реквизиты грузоотправителя (D 25)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="address" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Адрес (D 25.3)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="name" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Наименование (D 25.2)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="tin" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>ИИН/БИН (D 25.1)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="Participant">
    <xs:annotation>
      <xs:documentation>УСД (H)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="productShares">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="share" type="tns:ProductShare" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Информация по товарам (работам, услугам)</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="reorganizedTin" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>БИН реорганизованного лица (H 34.2)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="tin" type="xs:string" minOccurs="1">
        <xs:annotation>
          <xs:documentation>ИИН/БИН участника совместной деятельности (H 34.1)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ProductShare">
    <xs:annotation>
      <xs:documentation>Информация по товарам (работам, услугам)</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ns1:AbstractProductShare">
        <xs:sequence>
          <xs:element name="additional" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Дополнительные данные (H 19)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="additionalUnitNomenclature" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Дополнительная единица измерения (H 20)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="exciseAmount" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Акциз-Сумма (H 10)</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:decimal">
                <xs:fractionDigits value="2"/>
                <xs:totalDigits value="17"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element name="ndsAmount" minOccurs="1">
            <xs:annotation>
              <xs:documentation>НДС-Сумма (H 13)</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:decimal">
                <xs:fractionDigits value="2"/>
                <xs:totalDigits value="17"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element name="priceWithTax" minOccurs="1">
            <xs:annotation>
              <xs:documentation>Стоимость ТРУ с учетом НДС (H 15)</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:decimal">
                <xs:fractionDigits value="2"/>
                <xs:totalDigits value="17"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element name="priceWithoutTax" minOccurs="1">
            <xs:annotation>
              <xs:documentation>Стоимость ТРУ без учета НДС (H 7)</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:decimal">
                <xs:fractionDigits value="2"/>
                <xs:totalDigits value="17"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element name="productNumber">
            <xs:annotation>
              <xs:documentation>Номер продукта (товара, услуги)</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:int">
                <xs:maxInclusive value="200"/>
                <xs:minInclusive value="1"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element name="productNumberInSnt" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Номер продукта (товара, услуги) из СНТ (H 1)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="quantity" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Кол-во (объем) (H 6)</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:decimal">
                <xs:fractionDigits value="6"/>
                <xs:totalDigits value="18"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element name="turnoverSize" minOccurs="1">
            <xs:annotation>
              <xs:documentation>Размер оборота по реализации (H 11)</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:decimal">
                <xs:fractionDigits value="2"/>
                <xs:totalDigits value="17"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="Customer">
    <xs:annotation>
      <xs:documentation>Реквищиты получателя (C)</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ns1:AbstractCustomer">
        <xs:sequence>
          <xs:element name="address" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Адрес (C 18)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="branchTin" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>БИН филиала, выписавшего ЭСФ за голову</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="countryCode" type="xs:string" minOccurs="1">
            <xs:annotation>
              <xs:documentation>Код страны получателя. Обязательно заполняется если установлен статус CustomerType.NONRESIDENT и SellerType.EXPORTER (C 18.1)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="name" type="xs:string" minOccurs="1">
            <xs:annotation>
              <xs:documentation>Наименование получателя (C 17)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="reorganizedTin" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>БИН реорганизованного лица (B 16.1)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="shareParticipation" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Доля участия (С 17.1)</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:decimal">
                <xs:fractionDigits value="6"/>
                <xs:totalDigits value="18"/>
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element name="statuses" minOccurs="0">
            <xs:complexType>
              <xs:sequence>
                <xs:element name="status" type="tns:CustomerType" maxOccurs="unbounded">
                  <xs:annotation>
                    <xs:documentation>Категория получателя (С 20)</xs:documentation>
                  </xs:annotation>
                </xs:element>
              </xs:sequence>
            </xs:complexType>
          </xs:element>
          <xs:element name="tin" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>ИИН/БИН. Может отсутствовать если установлен статус CustomerType.NONRESIDENT (C 16)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="trailer" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Дополнительные сведения (C 19)</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="DeliveryTerm">
    <xs:annotation>
      <xs:documentation>Условия поставки (E)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="contractDate" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Дата договора(контракт) на поставку товаров (работ, услуг) (E 27.4)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="contractNum" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Номер договора(контракт) на поставку товаров (работ, услуг) (E 27.3)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="deliveryConditionCode" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Условия поставки (E 31.1)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="destination" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Пункт назначения поставляемых товаров (работ, услуг) (E 31)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="hasContract" type="xs:boolean">
        <xs:annotation>
          <xs:documentation>Договор/без договора (E 27.1 - true, E27.2 - false)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="term" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Условия оплаты по договору (E 28)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="transportTypeCode" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Способ отправления (E 29)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="warrant" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Номер доверенности на поставку товаров (работ, услуг) (E 30.1)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="warrantDate" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Дата доверенности на поставку товаров (работ, услуг) (E 30.2)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ProductSet">
    <xs:annotation>
      <xs:documentation>Данные по товарам, работам, услугам (G)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="currencyCode" type="xs:string" minOccurs="1">
        <xs:annotation>
          <xs:documentation>Код валюты (G 33.1)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="currencyRate" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Курс валюты (G 33.2)</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:decimal">
            <xs:fractionDigits value="6"/>
            <xs:totalDigits value="18"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="ndsRateType" type="tns:NdsRateType" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Тип НДС ('Без НДС – не РК')</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="products">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="product" type="tns:Product" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Данные по ТРУ</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="totalExciseAmount" minOccurs="1">
        <xs:annotation>
          <xs:documentation>Итоговая Акциз-Сумма (G 10)</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:decimal">
            <xs:fractionDigits value="2"/>
            <xs:totalDigits value="17"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="totalNdsAmount" minOccurs="1">
        <xs:annotation>
          <xs:documentation>Итоговая НДС-Сумма (G 13)</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:decimal">
            <xs:fractionDigits value="2"/>
            <xs:totalDigits value="17"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="totalPriceWithTax" minOccurs="1">
        <xs:annotation>
          <xs:documentation>Итоговая стоимость ТРУ с учетом НДС (G 14)</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:decimal">
            <xs:fractionDigits value="2"/>
            <xs:totalDigits value="17"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="totalPriceWithoutTax" minOccurs="1">
        <xs:annotation>
          <xs:documentation>Итоговая стоимость ТРУ без учета НДС (G 8)</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:decimal">
            <xs:fractionDigits value="2"/>
            <xs:totalDigits value="17"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="totalTurnoverSize" minOccurs="1">
        <xs:annotation>
          <xs:documentation>Итоговый размер оборота по реализации (G 11)</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:decimal">
            <xs:fractionDigits value="2"/>
            <xs:totalDigits value="17"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="Product">
    <xs:annotation>
      <xs:documentation>Товар (работа, услуга)</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="ns1:AbstractProduct">
        <xs:sequence>
